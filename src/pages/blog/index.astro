---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog — Veilus" description="Guides, tutorials, and insights on anti-detect browsers, browser fingerprinting, automation, and privacy.">
  <Navbar lang="en" />
  <main class="blog-page">
    <div class="container">
      <div class="blog-header" data-animate>
        <h1>Veilus <span class="text-gradient">Blog</span></h1>
        <p>Guides, comparisons, and deep-dives on anti-detect browsers, fingerprinting, and automation.</p>
      </div>

      {posts.length === 0 ? (
        <div class="blog-empty">
          <p>Coming soon — stay tuned! 🚀</p>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="blog-card" data-animate>
              {post.data.image && (
                <div class="blog-card-image">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  {post.data.tags.length > 0 && <span class="blog-card-tag">#{post.data.tags[0]}</span>}
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="read-more">Read more →</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .blog-page {
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-4xl);
    min-height: 80vh;
  }

  .blog-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .blog-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--space-md);
  }

  .blog-header p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 50ch;
    margin: 0 auto;
  }

  .blog-empty {
    text-align: center;
    padding: var(--space-4xl) 0;
    color: var(--color-text-muted);
    font-size: 1.125rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-xl);
  }

  .blog-card {
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    color: inherit;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    border-color: var(--color-border-light);
    box-shadow: var(--shadow-glow);
    transform: translateY(-3px);
    color: inherit;
  }

  .blog-card-image {
    height: 200px;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  .blog-card-body {
    padding: var(--space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .blog-card-tag {
    color: var(--color-cyan);
    background: rgba(0, 212, 255, 0.08);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
  }

  .blog-card-body h2 {
    font-size: 1.25rem;
    line-height: 1.3;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .blog-card-body p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
    max-width: none;
  }

  .read-more {
    color: var(--color-cyan);
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .blog-page {
      padding-top: calc(var(--nav-height) + var(--space-xl));
    }
  }
</style>
