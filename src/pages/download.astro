---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { t, defaultLang } from "../i18n/utils";

const i = t(defaultLang);
---

<Layout lang={defaultLang}>
  <Navbar />
  <main class="download-page">
    <section class="download-hero">
      <div class="container">
        <h1>
          {i.waitlist.title}
          <span class="text-gradient">{i.download.titleHighlight}</span>
        </h1>
        <p class="download-subtitle">{i.waitlist.subtitle}</p>

        <!-- Waitlist Form -->
        <form
          class="waitlist-form"
          id="dl-waitlist"
          data-source="download"
          data-lang={defaultLang}
        >
          <div class="waitlist-input-group">
            <input
              type="email"
              id="dl-email"
              placeholder={i.waitlist.placeholder}
              required
              autocomplete="email"
            />
            <button type="submit" class="btn btn-primary waitlist-btn">
              <span class="btn-text">{i.waitlist.cta}</span>
              <span class="btn-loader" aria-hidden="true"></span>
            </button>
          </div>
          <p class="waitlist-message" id="dl-message" aria-live="polite"></p>
        </form>

        <p class="waitlist-counter" id="dl-counter"></p>

        <!-- Platform Cards — Coming Soon -->
        <div class="platform-cards">
          <div class="platform-card" data-os="windows">
            <div class="platform-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M3 12V6.75l8-1.25V12H3zm0 .5h8v6.5L3 17.75V12.5zm9 0h9V3.5l-9 1.25V12.5zm0 .5v6.25L21 20.5V13H12z"
                ></path></svg
              >
            </div>
            <h3>Windows</h3>
            <p class="platform-version">{i.download.win64}</p>
            <span class="coming-soon-badge">Coming Soon</span>
            <span class="platform-size">.exe · ~120MB</span>
          </div>

          <div class="platform-card" data-os="macos">
            <div class="platform-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                ></path></svg
              >
            </div>
            <h3>macOS</h3>
            <p class="platform-version">{i.download.macUniversal}</p>
            <span class="coming-soon-badge">Coming Soon</span>
            <span class="platform-size">.dmg · ~150MB</span>
          </div>

          <div class="platform-card" data-os="linux">
            <div class="platform-icon">
              <svg viewBox="0 0 24 24" fill="currentColor"
                ><path
                  d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 00-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.536.058.399.116.728.04.97-.249.68-.28 1.145-.106 1.484.174.334.535.47.94.601.81.2 1.91.135 2.774.6.926.466 1.866.67 2.616.47.526-.116.97-.464 1.208-.946.587-.003 1.23-.269 2.26-.334.699-.058 1.574.267 2.577.2.025.134.063.198.114.333l.003.003c.391.778 1.113 1.368 1.884 1.43.777.07 1.589-.267 2.08-.97.466-.668.47-1.534.186-2.233-.136-.336-.35-.682-.545-.878a.588.588 0 00-.207-.206c-1.476-2.03-2.96-4.667-3.156-7.173-.097-1.47-.162-2.944.076-4.108.238-1.173.733-1.967 1.38-2.433l.044-.03a4.322 4.322 0 001.595-2.148c.376-.936.372-2.14-.144-3.166-.534-1.064-1.756-1.4-2.768-1.349z"
                ></path></svg
              >
            </div>
            <h3>Linux</h3>
            <p class="platform-version">{i.download.linuxX64}</p>
            <span class="coming-soon-badge">Coming Soon</span>
            <span class="platform-size">.AppImage · ~130MB</span>
          </div>
        </div>

        <!-- Trust Badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
              ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
            >
            <span>No personal data collected</span>
          </div>
          <div class="trust-badge">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="1" y="4" width="22" height="16" rx="2" ry="2"
              ></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg
            >
            <span>No credit card required</span>
          </div>
          <div class="trust-badge">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
              ></path><circle cx="12" cy="7" r="4"></circle></svg
            >
            <span>5 free profiles forever</span>
          </div>
        </div>
      </div>
    </section>

    <section class="system-req">
      <div class="container">
        <h2>{i.download.reqTitle}</h2>
        <div class="req-grid">
          <div class="req-card">
            <h4>Windows</h4>
            <ul>
              <li>Windows 10/11 (64-bit)</li>
              <li>4 GB RAM minimum</li>
              <li>500 MB disk space</li>
            </ul>
          </div>
          <div class="req-card">
            <h4>macOS</h4>
            <ul>
              <li>macOS 12+ (Monterey)</li>
              <li>Apple Silicon & Intel</li>
              <li>4 GB RAM minimum</li>
            </ul>
          </div>
          <div class="req-card">
            <h4>Linux</h4>
            <ul>
              <li>Ubuntu 20.04+ / Fedora 36+</li>
              <li>X11 or Wayland</li>
              <li>4 GB RAM minimum</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const API_BASE = "https://api.veilus.io";

  document.querySelectorAll(".waitlist-form").forEach((form) => {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const input = f.querySelector('input[type="email"]') as HTMLInputElement;
      const btn = f.querySelector(".waitlist-btn") as HTMLButtonElement;
      const msg = f.parentElement?.querySelector(
        ".waitlist-message",
      ) as HTMLElement;
      const email = input.value.trim();
      const source = f.dataset.source || "download";
      const lang = f.dataset.lang || "en";
      if (!email) return;
      btn.classList.add("loading");
      btn.disabled = true;
      msg.textContent = "";
      msg.className = "waitlist-message";
      try {
        const res = await fetch(`${API_BASE}/api/v1/waitlist`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, source, lang }),
        });
        const data = await res.json();
        if (res.ok && data.success) {
          f.classList.add("success");
          msg.className = "waitlist-message show success";
          msg.innerHTML = data.duplicate
            ? "✅ You're already on the list!"
            : "🎉 You're on the list!<br><small>We'll email you when Veilus is ready.</small>";
          input.disabled = true;
          btn.style.display = "none";
          loadCount();
        } else {
          msg.className = "waitlist-message show error";
          msg.textContent = data.error || "Something went wrong.";
        }
      } catch {
        msg.className = "waitlist-message show error";
        msg.textContent = "Something went wrong. Please try again.";
      } finally {
        btn.classList.remove("loading");
        btn.disabled = false;
      }
    });
  });

  async function loadCount() {
    try {
      const res = await fetch(`${API_BASE}/api/v1/waitlist/count`);
      const data = await res.json();
      if (data.count > 0) {
        document.querySelectorAll(".waitlist-counter").forEach((el) => {
          el.textContent = `${data.count}+ people are waiting`;
          el.classList.add("show");
        });
      }
    } catch {
      /* silent */
    }
  }
  loadCount();
</script>

<style>
  .download-page {
    padding-top: var(--nav-height);
  }
  .download-hero {
    padding: var(--space-3xl) 0;
    text-align: center;
    background: radial-gradient(
      ellipse 80% 50% at 50% -20%,
      rgba(0, 212, 255, 0.08),
      transparent
    );
  }
  .download-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-bottom: var(--space-md);
  }
  .download-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 50ch;
    margin: 0 auto var(--space-xl);
  }

  .waitlist-form {
    max-width: 480px;
    margin: 0 auto var(--space-xl);
  }
  .waitlist-input-group {
    display: flex;
    gap: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(0, 212, 255, 0.2);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }
  .waitlist-input-group:focus-within {
    border-color: rgba(0, 212, 255, 0.5);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.1);
  }
  .waitlist-input-group input {
    flex: 1;
    border: none;
    background: transparent;
    padding: 14px 16px;
    font-size: 0.9375rem;
    color: var(--color-text);
    outline: none;
    min-width: 0;
  }
  .waitlist-input-group input::placeholder {
    color: var(--color-text-muted);
  }
  .waitlist-btn {
    border: none;
    padding: 14px 24px;
    font-weight: 700;
    font-size: 0.875rem;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 0;
  }
  .waitlist-btn .btn-loader {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(0, 0, 0, 0.2);
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }
  .waitlist-btn.loading .btn-text {
    display: none;
  }
  .waitlist-btn.loading .btn-loader {
    display: inline-block;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .waitlist-message {
    font-size: 0.8125rem;
    margin-top: var(--space-sm);
    min-height: 1.5em;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .waitlist-message.show {
    opacity: 1;
  }
  .waitlist-message.success {
    color: var(--color-success, #22c55e);
  }
  .waitlist-message.error {
    color: #ef4444;
  }
  .waitlist-counter {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .waitlist-counter.show {
    opacity: 1;
  }
  .waitlist-form.success .waitlist-input-group {
    border-color: rgba(34, 197, 94, 0.4);
    background: rgba(34, 197, 94, 0.05);
  }

  .platform-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }
  .platform-card {
    position: relative;
    padding: var(--space-xl) var(--space-lg);
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    transition: border-color var(--transition-fast);
    opacity: 0.7;
  }
  .platform-card:hover {
    border-color: rgba(0, 212, 255, 0.3);
    opacity: 1;
  }
  .platform-icon {
    width: 48px;
    height: 48px;
    color: var(--color-text);
  }
  .platform-icon svg {
    width: 100%;
    height: 100%;
  }
  .platform-card h3 {
    font-size: 1.25rem;
    margin: 0;
  }
  .platform-version {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .coming-soon-badge {
    display: inline-block;
    margin-top: var(--space-xs);
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(0, 212, 255, 0.1);
    color: var(--color-accent);
    border: 1px solid rgba(0, 212, 255, 0.2);
  }
  .platform-size {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }
  .trust-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 8px 16px;
    border-radius: 99px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.02);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
  .trust-badge svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: var(--color-accent);
  }

  .system-req {
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border);
  }
  .system-req h2 {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
  .req-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }
  .req-card {
    padding: var(--space-lg);
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .req-card h4 {
    margin: 0 0 var(--space-sm);
    font-size: 1rem;
  }
  .req-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .req-card li {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    padding: 4px 0;
  }
  .req-card li::before {
    content: "→ ";
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .platform-cards,
    .req-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
    .waitlist-input-group {
      flex-direction: column;
    }
    .waitlist-btn {
      border-radius: 0 0 var(--radius-md) var(--radius-md);
    }
  }
</style>
