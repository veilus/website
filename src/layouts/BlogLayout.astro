---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, author = 'Veilus Team', image, tags = [] } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedFormatted = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${title} — Veilus Blog`} description={description}>
  <Navbar lang="en" />
  <main class="blog-post-page">
    <article class="container">
      <div class="blog-post-header">
        <div class="blog-post-meta">
          <a href="/blog" class="back-link">← Blog</a>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          {updatedFormatted && <span class="updated">Updated: {updatedFormatted}</span>}
        </div>
        <h1>{title}</h1>
        <p class="blog-post-desc">{description}</p>
        {tags.length > 0 && (
          <div class="blog-post-tags">
            {tags.map((tag) => <span class="tag">#{tag}</span>)}
          </div>
        )}
        <div class="blog-post-author">
          <span>By {author}</span>
        </div>
      </div>

      {image && (
        <div class="blog-post-hero">
          <img src={image} alt={title} />
        </div>
      )}

      <div class="blog-post-content">
        <slot />
      </div>

      <div class="blog-post-footer">
        <div class="blog-cta-box">
          <h3>Ready to try Veilus?</h3>
          <p>5 free profiles, no credit card required. Built with Rust for maximum performance.</p>
          <a href="/download" class="btn btn-primary">Download Free →</a>
        </div>
        <a href="/blog" class="btn btn-secondary">← Back to Blog</a>
      </div>
    </article>
  </main>
  <Footer lang="en" />
</Layout>

<style>
  .blog-post-page {
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-4xl);
    min-height: 80vh;
  }

  .blog-post-header {
    max-width: 780px;
    margin-bottom: var(--space-2xl);
  }

  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .back-link {
    color: var(--color-cyan);
    font-weight: 500;
  }

  .blog-post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: var(--space-md);
    background: linear-gradient(135deg, var(--color-text), var(--color-text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-post-desc {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: none;
    margin-bottom: var(--space-md);
  }

  .blog-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .tag {
    font-size: 0.8125rem;
    color: var(--color-cyan);
    background: rgba(0, 212, 255, 0.08);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    border: 1px solid rgba(0, 212, 255, 0.15);
  }

  .blog-post-author {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .blog-post-hero {
    margin-bottom: var(--space-2xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .blog-post-hero img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
  }

  /* Article body styles */
  .blog-post-content {
    max-width: 780px;
  }

  .blog-post-content :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .blog-post-content :global(h3) {
    font-size: 1.2rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .blog-post-content :global(p) {
    margin-bottom: var(--space-md);
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: none;
    font-size: 1.0625rem;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
    color: var(--color-text-secondary);
  }

  .blog-post-content :global(li) {
    margin-bottom: var(--space-xs);
    line-height: 1.7;
  }

  .blog-post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .blog-post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-elevated);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--color-cyan);
  }

  .blog-post-content :global(pre) {
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    overflow-x: auto;
    margin-bottom: var(--space-lg);
  }

  .blog-post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .blog-post-content :global(blockquote) {
    border-left: 3px solid var(--color-cyan);
    padding-left: var(--space-lg);
    margin: var(--space-lg) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .blog-post-content :global(img) {
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: var(--space-lg) 0;
  }

  .blog-post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: 0.9375rem;
  }

  .blog-post-content :global(th),
  .blog-post-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .blog-post-content :global(th) {
    color: var(--color-text);
    font-weight: 600;
    background: var(--bg-elevated);
  }

  .blog-post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-2xl) 0;
  }

  /* Footer CTA */
  .blog-post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 780px;
  }

  .blog-cta-box {
    background: var(--bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-align: center;
  }

  .blog-cta-box h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    background: linear-gradient(135deg, var(--color-cyan), var(--color-indigo));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-cta-box p {
    color: var(--color-text-secondary);
    margin: 0 auto var(--space-md);
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .blog-post-page {
      padding-top: calc(var(--nav-height) + var(--space-xl));
    }
    .blog-post-meta {
      flex-wrap: wrap;
      gap: var(--space-sm);
    }
  }
</style>
