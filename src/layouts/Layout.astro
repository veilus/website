---
import type { Lang } from "../i18n/utils";
import {
  t,
  languages,
  supportedLangs,
  defaultLang,
  getLocalizedPath,
  getHreflangs,
} from "../i18n/utils";

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
}

const lang = Astro.props.lang || defaultLang;
const i = t(lang);
const { title = i.meta.title, description = i.meta.description } = Astro.props;

const siteUrl = "https://veilus.io";
const hreflangs = getHreflangs(Astro.url.pathname, siteUrl);
const canonicalUrl =
  lang === defaultLang ? `${siteUrl}/` : `${siteUrl}/${lang}/`;

// Google Analytics 4 — Replace G-XXXXXXXXXX with your Measurement ID
const GA_ID = "G-CZ9G6B0L4M";

// JSON-LD Structured Data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Veilus",
  applicationCategory: "BrowserApplication",
  operatingSystem: "Windows, macOS, Linux",
  description: i.meta.description,
  url: siteUrl,
  offers: {
    "@type": "AggregateOffer",
    lowPrice: "0",
    highPrice: "79",
    priceCurrency: "USD",
    offerCount: "4",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    ratingCount: "127",
    bestRating: "5",
  },
  featureList: [
    "Anti-detect fingerprinting",
    "Built-in automation",
    "Visual canvas flow builder",
    "AI agent integration",
    "End-to-end encrypted sync",
    "Smart scheduling",
  ],
};

// Organization JSON-LD
const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Veilus",
  url: siteUrl,
  logo: `${siteUrl}/logo-512.png`,
  description:
    "Anti-detect browser with built-in automation platform. Native Chromium engine — 3x faster, 80% less RAM.",
  sameAs: [
    "https://t.me/veilusbrowser",
    "https://x.com/veilusbrowser",
    "https://github.com/veilus",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer support",
    url: "https://t.me/veilusbrowser",
  },
};

// WebSite JSON-LD (sitelinks search box)
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Veilus",
  url: siteUrl,
  description: i.meta.description,
};

// FAQ JSON-LD (for rich snippets)
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: i.faq.items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<!DOCTYPE html>
<html lang={lang} dir={languages[lang].dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0B0F1A" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
    ></script>
    <script
      set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${GA_ID}');`}
    ></script>

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Veilus — Anti-detect browser" />
    <meta property="og:site_name" content="Veilus" />
    <meta property="og:locale" content={lang === "en" ? "en_US" : lang} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- Hreflang for SEO -->
    {
      hreflangs.map(({ lang: l, href }) => (
        <link rel="alternate" hreflang={l} href={href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)}
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}
    ></script>
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}
    ></script>

    <!-- Fonts (preconnect for performance) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("animate-fade-in");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
      );
      document
        .querySelectorAll("[data-animate]")
        .forEach((el) => observer.observe(el));
    </script>

    <!-- GA4 Custom Events -->
    <script src="/analytics.js" defer></script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
