---
import type { Lang } from '../i18n/utils';
import { t, defaultLang } from '../i18n/utils';
interface Props { lang?: Lang; }
const lang = Astro.props.lang || defaultLang;
const i = t(lang);

const icons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="2"/></svg>`,
];
const colors = ['cyan', 'indigo', 'gold', 'cyan', 'indigo', 'gold'];
const colorMap: Record<string, string> = { cyan: 'var(--color-cyan)', indigo: 'var(--color-indigo)', gold: 'var(--color-gold-light)' };
---
<section class="section features" id="features" data-animate>
  <div class="container">
    <div class="section-header">
      <span class="badge">{i.features.badge}</span>
      <h2 class="mt-md">{i.features.title}<br /><span class="text-gradient">{i.features.titleHighlight}</span></h2>
      <p>{i.features.subtitle}</p>
    </div>
    <div class="features-grid">
      {i.features.items.map((f, idx) => (
        <div class="feature-card card" style={`--accent: ${colorMap[colors[idx]]}`}>
          <div class="feature-icon" set:html={icons[idx]} />
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
          <span class="badge feature-badge">{f.badge}</span>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); }
  .feature-card { display: flex; flex-direction: column; gap: var(--space-md); cursor: default; }
  .feature-card:hover { border-color: var(--accent, var(--color-border-light)); box-shadow: 0 0 25px color-mix(in srgb, var(--accent, var(--color-cyan)) 15%, transparent); }
  .feature-icon { width: 40px; height: 40px; padding: 8px; border-radius: var(--radius-md); background: color-mix(in srgb, var(--accent, var(--color-cyan)) 10%, transparent); color: var(--accent, var(--color-cyan)); display: flex; align-items: center; justify-content: center; }
  .feature-icon :global(svg) { width: 24px; height: 24px; }
  .feature-title { font-size: 1.125rem; font-weight: 700; }
  .feature-desc { font-size: 0.9375rem; line-height: 1.6; flex-grow: 1; }
  .feature-badge { align-self: flex-start; }
  @media (max-width: 1024px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .features-grid { grid-template-columns: 1fr; } }
</style>
